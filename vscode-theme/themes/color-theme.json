{
  "name": "Archon Grid",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "enumMember": {
      "foreground": "#26be5e"
    },
    "variable.constant": {
      "foreground": "#9d72ff"
    },
    "variable.defaultLibrary": {
      "foreground": "#26be5e"
    }
  },
  "tokenColors": [
    // * Main
    {
      "name": "default",
      "scope": ["block.scope.end", "block.scope.begin", "meta.tag", "meta.brace.square", "meta.template.expression", "punctuation.separator.list.comma", "punctuation.separator.key-value", "punctuation.separator.delimiter", "function.brace", "variable.parameter.function", "support.type.property-name", "support.constant.property-value", "invalid", "token.package"],
      "settings": {
        "foreground": "#b5ccba"
      }
    },
    {
      "name": "rgb",
      "scope": "rgb-value",
      "settings": {
        "foreground": "#9d72ff"
      }
    },
    // * Punctuation
    {
      "name": "punctuation",
      "scope": ["punctuation.section.embedded", "variable.interpolation", "punctuation.definition.string.begin", "punctuation.definition.string.end"],
      "settings": {
        "foreground": "#f9c859"
      }
    },
    {
      "name": "punctuation-highlighted",
      "scope": ["punctuation.quasi.element", "punctuation.section.embedded", "punctuation.definition.constant", "punctuation.definition.template-expression.begin", "punctuation.definition.template-expression.end"],
      "settings": {
        "foreground": "#9d72ff"
      }
    },
    {
      "name": "comments",
      "scope": "comment, punctuation.definition.comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#b5ccba"
      }
    },
    {
      "name": "comment",
      "scope": "comment.line.double-slash,comment.block.documentation",
      "settings": {
        "fontStyle": "italic"
      }
    },
    // * Text Decoration
    {
      "name": "italic",
      "scope": ["entity.other.attribute-name", "entity.other.attribute-name", "variable.parameter", "variable.language.super"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "diff",
      "scope": "meta.diff.header.from-file,meta.diff.header.to-file,punctuation.definition.from-file.diff,punctuation.definition.to-file.diff",
      "settings": {
        "foreground": "#26be5e"
      }
    },
    {
      "name": "bold",
      "scope": "punctuation.definition.bold",
      "settings": {
        "foreground": "#9d72ff"
      }
    },
    // * Regex
    {
      "name": "regex-text",
      "scope": "string.regexp",
      "settings": {
        "foreground": "#ff6b6b" // Changed to Red for clear standalone visibility
      }
    },
    // * Code
    {
      "name": "keywords",
      "scope": [
        "keyword",
        "support.variable.dom",
        "support.variable.property.dom",
        "support.type.object.dom",

        "support.variable.property.process",
        "support.constant.json",
        "support.constant.font-name",
        "support.constant.property.math",

        "constant.character.escape",
        "constant.character.entity",

        /* Variable declaration */
        "token.storage",
        "storage"
      ],
      "settings": {
        "foreground": "#9d72ff" 
      }
    },
    {
      "name": "functions",
      "scope": ["entity.name.function", "support.function", "variable.function", "keyword.other.special-method"],
      "settings": {
        "foreground": "#26be5e" 
      }
    },
    {
      "name": "string",
      "scope": "string",
      "settings": {
        "foreground": "#f9c859" // Yellow (standard for strings)
      }
    },
    {
      "name": "constants",
      "scope": [
        "constant",
        "entity.name.namespace",
        "variable.language",
        "support.constant.math",
        "support.type.primitive",

        /* Modules */
        "entity.name.type.module",
        "support.module.node",
        "support.type.object.module",
        "support.module.node"
      ],
      "settings": {
        "foreground": "#5494fc" 
      }
    },
    {
      "name": "variables",
      "scope": ["variable", "meta.object-literal.key", "support.variable.property", "support.variable.object.process", "support.variable.object.node", "support.type.object.console"],
      "settings": {
        "foreground": "#aee29e" 
      }
    },
    {
      "name": "text-highlighted",
      "scope": ["keyword.operator.assignment.compound", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#9d72ff" 
      }
    },
    {
      "name": "text-highlighted",
      "scope": ["variable.other.property", "variable.parameter", "support.function", "text.variable", "text.bracketed"],
      "settings": {
        "foreground": "#ffa96b" 
      }
    },
    {
      "name": "classes-and-types",
      "scope": ["support.class", "entity.name.type.namespace", "entity.name.type.class", "entity.name.class", "variable.other.class", "entity.other.inherited-class", "entity.name.type", "support.type.primitive"],
      "settings": {
        "foreground": "#36d6c3"
      }
    },
    {
      "name": "types-highlighted",
      "scope": "support.type.builtin",
      "settings": {
        "foreground": "#299a82" 
      }
    },
        // * JSON
    {
      "name": "json",
      "scope": ["source.json meta.structure.dictionary.json > string.quoted.json", "support.type.property-name.json"],
      "settings": {
        "foreground": "#ffa96b"
      }
    },
    {
      "name": "json-values",
      "scope": ["source.json meta.structure.dictionary.json > value.json > string.quoted.json", "source.json meta.structure.array.json > value.json > string.quoted.json", "source.json meta.structure.dictionary.json > value.json > string.quoted.json > punctuation", "source.json meta.structure.array.json > value.json > string.quoted.json > punctuation"],
      "settings": {
        "foreground": "#f9c859"
      }
    },
// * HTML / SCSS 
    {
      "name": "html-text",
      "scope": [
        "text.html",
        "text.html.basic",
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#aee29e"
      }
    },
    {
      "name": "attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#26be5e"
      }
    },
    {
      "name": "html",
      "scope": ["entity.name.tag", "meta.selector"],
      "settings": {
        "foreground": "#9d72ff" 
      }
    },
    // * CSS / SCSS
    {
      "name": "styling-properties-name",
      "scope": ["source.css support.type.property-name", "source.sass support.type.property-name", "source.scss support.type.property-name", "source.less support.type.property-name", "source.stylus support.type.property-name", "source.postcss support.type.property-name"],
      "settings": {
        "foreground": "#36d6c3" 
      }
    },
    {
      "name": "styling-class",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.class.scss",
        "entity.other.attribute-name.class.sass",
        "entity.other.attribute-name.class.less",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.id.scss",
        "source.css entity.other.attribute-name.class",
        "source.scss entity.other.attribute-name.class",
        "meta.selector.scss entity.other.attribute-name.class",
        "meta.selector.sass entity.other.attribute-name.class",
        "meta.selector.css entity.other.attribute-name.class",
        "meta.property-list.css entity.other.attribute-name.class",
        "meta.property-list.css entity.other.attribute-name.css",
        "meta.property-list.css meta.selector.css entity.other.attribute-name.class",
        "source.css meta.property-list.css entity.other.attribute-name.css"
      ],
      "settings": {
        "foreground": "#f9c859" 
      }
    },
    {
      "name": "styling-selector",
      "scope": ["selector.css", "selector.scss", "selector.sass", "entity.other.attribute-name.pseudo-element", "entity.other.attribute-name.pseudo-class"],
      "settings": {
        "foreground": "#5494fc" 
      }
    },
    {
      "name": "styling-operators",
      "scope": ["keyword.operator.css", "keyword.operator.scss", "keyword.operator.less", "support.type.vendored.property-name.css", "support.type.vendored.property-name.scss", "support.constant.property-value.scss", "support.constant.property-value.css", "support.constant.color.css", "support.constant.color.scss"],
      "settings": {
        "foreground": "#9d72ff" 
      }
    },
    // * Markup
    {
      "name": "markup-heading-default",
      "scope": "markup.heading",
      "settings": {
        "foreground": "#ffa96b"
      }
    },
    {
      "name": "markup-heading",
      "scope": ["markup.heading punctuation.definition.heading", "entity.name.section"],
      "settings": {
        "foreground": "#26be5e"
      }
    },
    {
      "name": "markup-highlighted",
      "scope": ["punctuation.definition.italic", "todo.emphasis", "todo.bold", "markup.italic", "markup.bold"],
      "settings": {
        "foreground": "#9d72ff"
      }
    },
    {
      "name": "markup-link",
      "scope": "comment markup.link",
      "settings": {
        "foreground": "#36d6c3"
      }
    },
    {
      "name": "markup-diff",
      "scope": "markup.changed.diff",
      "settings": {
        "foreground": "#9d72ff"
      }
    },
    {
      "name": "markup-inserted-diff",
      "scope": "markup.inserted.diff",
      "settings": {
        "foreground": "#f9c859"
      }
    },
    {
      "name": "markup-deleted.diff",
      "scope": "markup.deleted.diff",
      "settings": {
        "foreground": "#ffa96b"
      }
    },
    // * Tokens
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#26be5e"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#9d72ff"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#ff6b6b"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#9d72ff"
      }
    },
        // * Fallbacks & Invalid
    {
      "name": "invalid-unrecognized",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#e0e3e4"
      }
    }
  ],
